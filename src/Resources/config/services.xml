<?xml version="1.0" encoding="UTF-8" ?>
<container xmlns="http://symfony.com/schema/dic/services"
           xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
           xsi:schemaLocation="http://symfony.com/schema/dic/services
        https://symfony.com/schema/dic/services/services-1.0.xsd">

    <services>
        <service id="lordjancso_translation.command.export_translations" class="Lordjancso\TranslationBundle\Command\ExportTranslationsCommand">
            <argument type="service" id="lordjancso_translation.service.translation_exporter" />
            <argument type="service" id="lordjancso_translation.service.translation_file_manager" />
            <argument type="service" id="filesystem" />
            <argument type="string">%kernel.project_dir%</argument>
            <tag name="console.command" />
        </service>

        <service id="lordjancso_translation.command.import_translations" class="Lordjancso\TranslationBundle\Command\ImportTranslationsCommand">
            <argument type="service" id="Lordjancso\TranslationBundle\Service\TranslationManager" />
            <argument type="service" id="lordjancso_translation.service.translation_importer" />
            <argument type="string">%kernel.project_dir%</argument>
            <tag name="console.command" />
        </service>

        <service id="lordjancso_translation.command.extract_translations" class="Lordjancso\TranslationBundle\Command\ExtractTranslationsCommand">
            <argument type="service" id="lordjancso_translation.service.translation_file_manager" />
            <argument>%lordjancso_translation.extract.exclude_domains%</argument>
            <tag name="console.command" />
        </service>

        <service id="lordjancso_translation.service.translation_file_manager" class="Lordjancso\TranslationBundle\Service\TranslationFileManager">
            <argument type="service" id="filesystem" />
            <argument type="string">%kernel.project_dir%</argument>
            <argument type="string">%lordjancso_translation.extract.translations_dir%</argument>
        </service>

        <service id="lordjancso_translation.extractor.form_type" class="Lordjancso\TranslationBundle\Extractor\FormTypeExtractor">
            <tag name="translation.extractor" alias="form_type" />
        </service>

        <service id="lordjancso_translation.extractor.constraint_message" class="Lordjancso\TranslationBundle\Extractor\ConstraintMessageExtractor">
            <tag name="translation.extractor" alias="constraint_message" />
        </service>

        <service id="lordjancso_translation.controller.translations" class="Lordjancso\TranslationBundle\Controller\TranslationController" public="true">
            <argument type="service" id="Lordjancso\TranslationBundle\Service\TranslationStats" />
            <argument type="service" id="twig" />
            <argument>%lordjancso_translation.managed_locales%</argument>
        </service>

        <service id="lordjancso_translation.event_listener.translation_entity_listener" class="Lordjancso\TranslationBundle\EventListener\TranslationEntityListener">
            <tag name="doctrine.orm.entity_listener" entity="Lordjancso\TranslationBundle\Entity\TranslationKey" event="prePersist" />
            <tag name="doctrine.orm.entity_listener" entity="Lordjancso\TranslationBundle\Entity\TranslationKey" event="preUpdate" />
            <tag name="doctrine.orm.entity_listener" entity="Lordjancso\TranslationBundle\Entity\TranslationValue" event="prePersist" />
            <tag name="doctrine.orm.entity_listener" entity="Lordjancso\TranslationBundle\Entity\TranslationValue" event="preUpdate" />
        </service>

        <service id="lordjancso_translation.service.translation_exporter" class="Lordjancso\TranslationBundle\Service\TranslationExporter">
            <argument type="service" id="doctrine.orm.entity_manager" />
        </service>

        <service id="lordjancso_translation.service.translation_importer" class="Lordjancso\TranslationBundle\Service\TranslationImporter">
            <argument type="service" id="doctrine.orm.entity_manager" />
        </service>

        <service id="Lordjancso\TranslationBundle\Service\TranslationManager">
            <argument type="service" id="doctrine.orm.entity_manager" />
            <argument>%lordjancso_translation.managed_locales%</argument>
        </service>

        <service id="Lordjancso\TranslationBundle\Service\TranslationStats">
            <argument type="service" id="doctrine.orm.entity_manager" />
            <argument>%lordjancso_translation.managed_locales%</argument>
        </service>

        <service id="lordjancso_translation.translation.database_loader" class="Lordjancso\TranslationBundle\Translation\DatabaseLoader">
            <argument type="service" id="doctrine.orm.entity_manager" />
            <tag name="translation.loader" alias="ljdb" />
        </service>
    </services>
</container>
